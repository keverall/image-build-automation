    <!--HPEOneView.Appliance.Update.Pending-->
    <View>
      <Name>UpdatePending</Name>
      <ViewSelectedBy>
        <TypeName>HPEOneView.Appliance.Update.Pending</TypeName>
      </ViewSelectedBy>
      <ListControl>
        <ListEntries>
          <ListEntry>
            <ListItems>
              <ListItem>
                <Label>Version</Label>
                <PropertyName>version</PropertyName>
              </ListItem>
              <ListItem>
                <Label>RebootRequired</Label>
                <ScriptBlock>if ($_.rebootRequired) { "Yes" } else { "No" }</ScriptBlock>
              </ListItem>
              <ListItem>
                <Label>UpgradeTime</Label>
                <PropertyName>estimatedUpgradeTime</PropertyName>
