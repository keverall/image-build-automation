# Environment Configuration for Maintenance Mode Scripts
# Copy this file to .env and fill in your values

# Environment: Test or Prod
ENVIRONMENT=Test

# SCOM Connection Settings
SCOM_ADMIN_USER=
SCOM_ADMIN_PASSWORD=
SCOM_HOST=

# OneView Connection Settings
ONEVIEW_USER=
ONEVIEW_PASSWORD=
ONEVIEW_HOST=

# Optional: Override hosts (if not set, will use connection_hosts.json based on ENVIRONMENT)
# SCOM_OVERRIDE_HOST=
# ONEVIEW_OVERRIDE_HOST=
