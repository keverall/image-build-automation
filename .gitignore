# === Generated Output (build artifacts) ===
# Note: docs/dynamic-code-docs/ is tracked in git (auto-generated docs that are reviewed)
# .gitkeep files are tracked to preserve directory structure
!generated/.gitkeep
!generated/base_iso/.gitkeep
!generated/output/.gitkeep
!generated/output/patched/.gitkeep
!generated/output/firmware/.gitkeep
!generated/output/combined/.gitkeep
!generated/patched_iso/.gitkeep
!generated/logs/.gitkeep
!generated/logs/testing/.gitkeep
!generated/logs/production/.gitkeep
!generated/logs/audit/.gitkeep
!generated/scheduled_jobs/.gitkeep
!generated/htmlcov/.gitkeep
generated/*.iso
generated/base_iso/*
generated/output/*
generated/patched_iso/*
generated/logs/testing/*
generated/logs/production/*
generated/logs/audit/*
generated/logs/build_reports/*
!generated/logs/build_reports/.gitkeep
generated/logs/deployment/*
!generated/logs/deployment/.gitkeep
generated/logs/testing build_reports/*

